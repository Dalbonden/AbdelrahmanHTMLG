# =========================================================================
# Miljövariabler – KOPIERA denna fil till .env och fyll i riktiga värden.
# Committa ALDRIG .env med riktiga hemligheter.
# =========================================================================

# --- Databas (Postgres) ---
# Lokalt exempel: postgresql://user:password@localhost:5432/shopen
DATABASE_URL="postgresql://user:password@localhost:5432/shopen?schema=public"

# --- Autentisering / sessioner ---
# Signerar sessionscookies. Generera: openssl rand -base64 32
SESSION_SECRET="byt-ut-mig-mot-en-lang-slumpmassig-strang"

# --- Stripe (betalning) ---
# Hämtas från https://dashboard.stripe.com/apikeys (använd TEST-nycklar lokalt)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook-signeringshemlighet (stripe listen / dashboard)
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- App-kryptering (AES-256-GCM för känslig data i vila) ---
# Generera: openssl rand -base64 32
APP_ENCRYPTION_KEY="byt-ut-mig-32-byte-base64-nyckel"

# --- Publik bas-URL ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
